# Copy this file to .env for local development. Never commit .env.
# Production values are set in the Railway dashboard, not in this file.

# PostgreSQL connection string. Railway injects this automatically when a
# Postgres plugin is attached. For local Postgres use e.g.:
#   postgresql://localhost/bytebooks_dev
# Leave unset to fall back to local SQLite (sqlite:///bytebooks.db).
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT signing secret. Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-32-byte-hex-string

# Public URL of the deployed frontend (Vercel), used for CORS.
FRONTEND_URL=https://your-frontend.vercel.app
